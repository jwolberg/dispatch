# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Local runtime data (SQLite db, etc.)
data/

# Env / secrets
.env
.env.local
.env.*.local
# Any local copy of .env is a copy of its secrets. `.env.example` is the one
# tracked file here, so it is re-admitted below.
.env.*
!.env.example
*.pem
*.key

# Logs
*.log
npm-debug.log*

# Coverage / test artifacts
coverage/

# OS files
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
.TerMinal/backlog/.next-id.lock
.TerMinal/sessions/.next-id.lock
.status.md

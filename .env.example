# Dispatch environment configuration. Copy to `.env` and fill in.
# Secrets are loaded server-side only and never sent to the browser.

# Anthropic Messages API key (spec chat + ticket generation)
ANTHROPIC_API_KEY=

# GitHub fine-grained PAT: Issues (RW), Pull requests (RW), Contents (R), Actions (R)
# Still required even once a GitHub App is registered: three account-level calls
# (rate-limit probe, /api/health, repo discovery) have no installation to resolve
# against, and a repo outside every installation is reachable only through it.
GITHUB_TOKEN=

# AES-256 key (base64, 32 bytes) encrypting the GitHub App's private key, client
# secret, and webhook secret at rest in SQLite. Required only once an App is
# registered -- but if it is lost while one is, Dispatch REFUSES TO BOOT rather
# than silently falling back to GITHUB_TOKEN, and the App must be re-registered.
#
# Generate one, appending only if absent. A bare `>>` run twice leaves two keys;
# dotenv takes the LAST, so the first silently becomes dead weight:
#
#   grep -q '^DISPATCH_ENCRYPTION_KEY=' .env \
#     || echo "DISPATCH_ENCRYPTION_KEY=$(openssl rand -base64 32)" >> .env
#
DISPATCH_ENCRYPTION_KEY=

# GitLab PAT with `api` scope (optional until GitLab repos are tracked)
GITLAB_TOKEN=

# Base URL for self-hosted GitLab (optional; defaults to https://gitlab.com)
GITLAB_HOST=

# Backend port (default 3001)
PORT=3001

# Backend bind host. Defaults to 127.0.0.1 (localhost-only).
# Binding to any non-local interface requires ALLOW_NONLOCAL=1 (see below).
HOST=127.0.0.1

# Set to 1 to permit binding to a non-localhost interface. Leave unset for safety.
ALLOW_NONLOCAL=

# Optional shared-password gate (HTTP Basic Auth). If set, every request needs
# this password (any username). Leave blank for localhost-only use. Use a
# high-entropy value if the deployment is internet-reachable.
DISPATCH_PASSWORD=

# Optional Slack notifications. Paste a Slack Incoming Webhook URL to mirror the
# activity feed (issue filed, column changes, PR opened, steered, merged, skills)
# into a channel. Leave blank to disable. Create one at:
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
